{
    "name": "miiizawadzki/php-mint-framework",
    "description": "A minimal PHP framework",
    "version": "0.0.0",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Mint\\Core\\": "core/"
        },
        "files": [
            "helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "require-dev": {
        "pestphp/pest": "*"
    }
}
